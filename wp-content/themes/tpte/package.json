{
  "name": "tpte",
  "version": "1.0.0",
  "description": "TPTE - A custom WordPress theme based on Acadia template",
  "author": "George Georgiou",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "WordPress",
    "Theme",
    "Education",
    "University"
  ],
  "homepage": "https://georgiou.dev",
  "main": "assets/js/main.js",
  "scripts": {
    "dev": "npm-run-all --parallel watch:scss watch:js",
    "build": "npm-run-all build:scss build:js",
    "watch": "npm-run-all --parallel watch:scss watch:js",
    "watch:scss": "sass --watch assets/scss:assets/css --style expanded --source-map",
    "watch:js": "webpack --watch --mode development",
    "build:scss": "sass assets/scss:assets/css --style compressed --no-source-map",
    "build:js": "webpack --mode production",
    "compile:css": "sass sass/style.scss:style.css assets/scss/main.scss:assets/css/main.css --style expanded",
    "compile:rtl": "rtlcss style.css style-rtl.css",
    "lint:scss": "stylelint 'sass/**/*.scss' 'assets/scss/**/*.scss'",
    "lint:js": "eslint 'assets/js/src/**/*.js' 'js/**/*.js'",
    "lint:fix:scss": "stylelint 'sass/**/*.scss' 'assets/scss/**/*.scss' --fix",
    "lint:fix:js": "eslint 'assets/js/src/**/*.js' 'js/**/*.js' --fix",
    "bundle": "npm run build && dir-archiver --src . --dest ../tpte.zip --exclude .DS_Store .stylelintrc.json .eslintrc .git .gitattributes .github .gitignore node_modules vendor package-lock.json .travis.yml sass assets/scss assets/js/src style.css.map yarn.lock webpack.config.js",
    "postinstall": "npm run build"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@wordpress/scripts": "^31.3.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "dir-archiver": "^2.0.0",
    "mini-css-extract-plugin": "^2.7.6",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.1",
    "rtlcss": "^4.1.0",
    "sass": "^1.69.0",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "stylelint": "^15.10.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "jquery": "^3.7.1"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ],
  "rtlcssConfig": {
    "options": {
      "autoRename": false,
      "autoRenameStrict": false,
      "blacklist": {},
      "clean": true,
      "greedy": false,
      "processUrls": false,
      "stringMap": []
    },
    "plugins": [],
    "map": false
  }
}
