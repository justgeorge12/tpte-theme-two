# Copy this file to .env and fill in real values. .env is git-ignored.
#
# IMPORTANT: Docker Compose interpolates `$` in .env values. A literal `$` in a
# password must be escaped as `$$`, otherwise the part after `$` is silently
# dropped. Easiest path: use passwords WITHOUT `$`.

# DB
DB_USER=tpte_admin
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-too
DB_PORT=3316
# WP
WP_PORT=4001
# phpMyAdmin
PMA_PORT=8081
